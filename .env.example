# AutoVideo Studio Configuration

# Application
APP_NAME="AutoVideo Studio"
ENVIRONMENT="development"

# Database
DATABASE_URL="sqlite:////workspace/db/dev.sqlite3"

# LLM Provider (openai, anthropic, local)
LLM_PROVIDER="openai"
LLM_API_KEY="sk-your-openai-api-key-here"

# Image Generation Provider (stability, midjourney, local)
IMAGE_PROVIDER="stability"
IMAGE_API_KEY="your-stability-api-key-here"

# Text-to-Speech Provider (azure, elevenlabs, gcp, local)
TTS_PROVIDER="azure"
TTS_API_KEY="your-tts-api-key-here"

# Video Generation Defaults
DEFAULT_LANGUAGES="en,it,fr,de,es,hi,zh"
DEFAULT_MIN_DURATION_MIN=5
DEFAULT_MAX_DURATION_MIN=10

# Scheduling
SCHEDULER_INTERVAL_MINUTES=15

# Storage
STORAGE_DIR="/workspace/storage"