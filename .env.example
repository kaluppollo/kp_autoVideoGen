# Ambiente di sviluppo
ENVIRONMENT=development
APP_NAME=AutoVideo Studio

# Database
DATABASE_URL=sqlite:////workspace/db/dev.sqlite3

# Provider esterni (inserire chiavi reali se disponibili)
LLM_PROVIDER=openai
LLM_API_KEY=
IMAGE_PROVIDER=stability
IMAGE_API_KEY=
TTS_PROVIDER=azure
TTS_API_KEY=

# Scheduler
SCHEDULER_INTERVAL_MINUTES=15

# Storage
STORAGE_DIR=/workspace/storage